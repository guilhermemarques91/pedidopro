# Servidor
PORT=3001
NODE_ENV=development

# Banco de dados (PostgreSQL local para dev)
DATABASE_URL=postgresql://user:password@localhost:5432/pedidopro_dev

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Evolution API (WhatsApp)
# - Dev no mesmo PC da Evolution: use 127.0.0.1 (NÃO localhost — o Topaz OFD quebra o loopback)
# - Backend remoto (HostGator): use a URL pública via Cloudflare tunnel
EVOLUTION_API_URL=http://127.0.0.1:8080
# EVOLUTION_API_URL=https://evolution.guimarques.dev.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=pedidopro

# IA para extração de preços
# Provedor: 'ollama' (local, sem custo — padrão) ou 'anthropic' (Claude API, paga)
AI_PROVIDER=ollama

# Ollama local (use 127.0.0.1, não localhost — Topaz quebra o loopback)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
# Modelo de visão (opcional, só para fotos/PDF escaneado): ex. qwen2.5vl:3b
# OLLAMA_VISION_MODEL=

# Claude API (só necessária se AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# CORS — origens liberadas (lista separada por vírgula). Default já cobre
# dev local + frontend de produção. Ajuste se o domínio do front mudar.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://pedidos.guimarques.dev.br

# Frontend
# - Dev local: http://localhost:3001
# - Produção: backend exposto via Cloudflare tunnel
VITE_API_URL=http://localhost:3001
# VITE_API_URL=https://pedidopro-api.guimarques.dev.br
