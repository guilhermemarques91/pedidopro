{
  "name": "pedidopro/backend-php",
  "description": "PedidoPro backend (PHP + MySQL) — porte do backend Node para HostGator shared hosting",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-curl": "*",
    "phpoffice/phpspreadsheet": "^2.3",
    "smalot/pdfparser": "^2.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "platform-check": false
  }
}
