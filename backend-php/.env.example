# PedidoPro backend PHP — variáveis de ambiente
# Copie para `.env` (fora do webroot público) e preencha. NÃO versionar o .env real.

# --- Banco (MySQL da HostGator / cPanel "MySQL Databases") ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=espac793_pedidopro
DB_USER=espac793_pedidopro
DB_PASS=troque-aqui

# --- Auth ---
# Pelo menos 16 chars. Gere algo aleatório e longo.
JWT_SECRET=troque-por-uma-chave-bem-grande
JWT_EXPIRES_DAYS=7

# --- Evolution API (WhatsApp) — roda no PC, exposta pelo tunnel ---
EVOLUTION_API_URL=https://evolution.guimarques.dev.br
EVOLUTION_API_KEY=troque-pela-chave-global
EVOLUTION_INSTANCE=pedidopro

# --- IA local (Ollama no PC, exposto pelo tunnel) ---
OLLAMA_URL=https://ollama.guimarques.dev.br
OLLAMA_MODEL=qwen2.5:3b
# Token de serviço do Cloudflare Access (se proteger o ollama.*). Opcional.
OLLAMA_CF_ACCESS_CLIENT_ID=
OLLAMA_CF_ACCESS_CLIENT_SECRET=

# --- Sincronização da caixa de entrada (cron do cPanel chama bin/sync-inbox.php) ---
INBOX_SYNC_DAYS=2
INBOX_SYNC_ENABLED=true

# --- CORS (vazio quando a API está na mesma origem do frontend) ---
# Liste origens separadas por vírgula se a API ficar em subdomínio diferente.
CORS_ORIGINS=

# dev | production
APP_ENV=production
